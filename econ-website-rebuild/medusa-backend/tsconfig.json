  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": ".medusa/server"
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", ".medusa"]
}
